          "caption": "Im Automatikmodus Sensoren mitteln (sonst reicht ein Unterschreiten)"
        },
        {
          "name": "StartPumpFirst",
          "type": "CheckBox",
          "caption": "Pumpe vor den Ventilen einschalten"
        },
        {
          "name": "PumpLeadTimeSeconds",
          "type": "NumberSpinner",
          "caption": "Vorlaufzeit Pumpe (Sekunden)"
