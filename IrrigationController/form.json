      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Sensoren",
      "items": [
        {
          "name": "MoistureSensor1",
          "type": "SelectVariable",
          "caption": "MiFlora Sensor 1 (optional)"
        },
        {
          "name": "MoistureSensor2",
          "type": "SelectVariable",
          "caption": "MiFlora Sensor 2 (optional)"
        },
        {
          "name": "RainLast24h",
          "type": "SelectVariable",
          "caption": "Regenmenge letzte 24 h (optional)"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Aktoren",
      "items": [
        {
          "name": "Valve1",
          "type": "SelectInstance",
          "caption": "Ventilaktor 1"
        },
        {
          "name": "Valve2",
          "type": "SelectInstance",
          "caption": "Ventilaktor 2"
        },
        {
          "name": "Pump",
          "type": "SelectInstance",
          "caption": "Pumpenaktor"
        }
      ]
    }
