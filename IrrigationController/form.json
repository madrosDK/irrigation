{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Allgemein",
      "items": [
        {
          "name": "Mode",
          "type": "Select",
          "caption": "Betriebsmodus",
          "options": [
            { "caption": "Manuell", "value": 1 },
            { "caption": "Zeitsteuerung", "value": 2 },
            { "caption": "Automatik", "value": 3 }
          ]
        },
        {
          "name": "DefaultDuration",
          "type": "NumberSpinner",
          "caption": "Standard-Beregnungsdauer je Kreis (Minuten)"
        },
        {
          "name": "PumpLeadTimeSeconds",
          "type": "NumberSpinner",
          "caption": "Pumpenvorlauf vor jedem Kreis (Sekunden)"
        },
        {
          "name": "PauseBetweenZonesSeconds",
          "type": "NumberSpinner",
          "caption": "Pause zwischen Kreisen (Sekunden)"
        },
        {
          "name": "MaxZones",
          "type": "NumberSpinner",
          "caption": "Maximale Kreise (1-10)"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Pumpe",
      "items": [
        {
          "name": "PumpInstance",
          "type": "SelectInstance",
          "caption": "Pumpenaktor Instanz (Shelly/xComfort, optional)"
        },
        {
          "name": "PumpVariable",
          "type": "SelectVariable",
          "caption": "Pumpen-Schaltvariable Bool (optional, wird bevorzugt)"
        },
        {
          "type": "Label",
          "caption": "Tipp: Wenn die Instanz nicht zuverlässig schaltet, wähle direkt die boolesche Schaltvariable des Aktors aus."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Neuen Kreis unter dieser Instanz anlegen",
      "onClick": "IRR_CreateZone($id);"
    },
    {
      "type": "Button",
      "caption": "Kreise aktualisieren",
      "onClick": "IRR_RefreshZones($id);"
    },
    {
      "type": "Button",
      "caption": "Sequenz manuell / zeitgesteuert starten",
      "onClick": "IRR_StartManualSequence($id);"
    },
    {
      "type": "Button",
      "caption": "Automatik prüfen und starten",
      "onClick": "IRR_StartAutomaticSequence($id);"
    },
    {
      "type": "Button",
      "caption": "Sequenz stoppen",
      "onClick": "IRR_StopSequence($id);"
    }
  ],
  "status": [
    {
      "code": 102,
      "icon": "active",
      "caption": "Instanz ist aktiv"
    },
    {
      "code": 200,
      "icon": "error",
      "caption": "Keine Kreise oder keine Pumpe konfiguriert"
    }
  ]
}
