      "code": 102,
      "icon": "active",
      "caption": "Instanz ist aktiv"
    },
    {
      "code": 104,
      "icon": "inactive",
      "caption": "Instanz ist inaktiv"
    },
    {
      "code": 200,
      "icon": "error",
