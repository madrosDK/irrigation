{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Allgemein",
      "items": [
        {
          "name": "Mode",
          "type": "Select",
          "caption": "Betriebsmodus",
          "options": [
            { "caption": "Manuell", "value": 1 },
            { "caption": "Zeitsteuerung", "value": 2 },
            { "caption": "Automatik", "value": 3 }
          ]
        },
        {
          "name": "Duration",
          "type": "NumberSpinner",
          "caption": "Beregnungsdauer (Minuten)"
        },
        {
          "name": "MoistureThreshold",
