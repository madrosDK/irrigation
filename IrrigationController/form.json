{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Master / Bewässerungssteuerung",
      "items": [
        {
          "name": "PumpLeadTimeSeconds",
          "type": "NumberSpinner",
          "caption": "Pumpenvorlauf beim Sequenzstart (Sekunden)"
        },
        {
          "name": "PumpEarlyOffSeconds",
          "type": "NumberSpinner",
          "caption": "Pumpe vor Ende der letzten Zone ausschalten (Sekunden)"
        },
        {
          "name": "PauseBetweenZonesSeconds",
          "type": "NumberSpinner",
          "caption": "Pause zwischen Zonen (Sekunden)"
        },
        {
          "name": "MaxZones",
          "type": "NumberSpinner",
          "caption": "Maximale Zonen (1-10)"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Pumpe",
      "items": [
        {
          "name": "PumpInstance",
          "type": "SelectInstance",
          "caption": "Pumpenaktor (Shelly oder xComfort)"
        },
        {
          "type": "Label",
          "caption": "Der Master steuert die Pumpe global. Das Modul sucht unter der Instanz automatisch die passende schaltbare Bool-Variable und schaltet diese mit RequestAction."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Neue Zone unter dieser Instanz anlegen",
      "onClick": "IRR_CreateArea($id);"
    },
    {
      "type": "Button",
      "caption": "Zonen aktualisieren",
      "onClick": "IRR_RefreshAreas($id);"
    },
    {
      "type": "Button",
      "caption": "Sequenz starten",
      "onClick": "IRR_StartManualSequence($id);"
    },
    {
      "type": "Button",
      "caption": "Sequenz stoppen",
      "onClick": "IRR_StopSequence($id);"
    }
  ],
  "status": [
    {
      "code": 102,
      "icon": "active",
      "caption": "Master ist aktiv"
    },
    {
      "code": 200,
      "icon": "error",
      "caption": "Keine Zonen oder keine Pumpe konfiguriert"
    }
  ]
}
