    {
      "type": "Button",
      "caption": "Automatik jetzt prüfen",
      "onClick": "IRR_EvaluateAutomatic($id);"
    },
    {
      "type": "Button",
      "caption": "Beregnung starten",
      "onClick": "IRR_StartIrrigation($id);"
    },
    {
      "type": "Button",
      "caption": "Beregnung stoppen",
      "onClick": "IRR_StopIrrigation($id);"
    }
  ],
  "status": [
