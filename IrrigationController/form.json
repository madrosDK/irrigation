{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Allgemein",
      "items": [
        {
          "name": "Mode",
          "type": "Select",
          "caption": "Betriebsmodus (alt / Kompatibilität)",
          "options": [
            { "caption": "Manuell", "value": 1 },
            { "caption": "Zeitsteuerung", "value": 2 },
            { "caption": "Automatik", "value": 3 }
          ]
        },
        {
          "name": "PumpLeadTimeSeconds",
          "type": "NumberSpinner",
          "caption": "Pumpenvorlauf beim Sequenzstart (Sekunden)"
        },
        {
          "name": "PumpEarlyOffSeconds",
          "type": "NumberSpinner",
          "caption": "Pumpe vor Ende der letzten Zone ausschalten (Sekunden)"
        },
        {
          "name": "PauseBetweenZonesSeconds",
          "type": "NumberSpinner",
          "caption": "Pause zwischen Kreisen / Zonen (Sekunden)"
        },
        {
          "name": "MaxZones",
          "type": "NumberSpinner",
          "caption": "Maximale Kreise/Zonen (1-10)"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Pumpe",
      "items": [
        {
          "name": "PumpInstance",
          "type": "SelectInstance",
          "caption": "Pumpenaktor (Shelly oder xComfort)"
        },
        {
          "type": "Label",
          "caption": "Das Modul sucht unter der Instanz automatisch die passende schaltbare Bool-Variable und schaltet diese mit RequestAction."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Neue Zone unter dieser Instanz anlegen",
      "onClick": "IRR_CreateArea($id);"
    },
    {
      "type": "Button",
      "caption": "Zonen aktualisieren",
      "onClick": "IRR_RefreshAreas($id);"
    },
    {
      "type": "Label",
      "caption": "Kompatibilität / alte Kreisstruktur"
    },
    {
      "type": "Button",
      "caption": "Neuen Kreis direkt unter dieser Instanz anlegen (alt)",
      "onClick": "IRR_CreateZone($id);"
    },
    {
      "type": "Button",
      "caption": "Kreise aktualisieren (alt)",
      "onClick": "IRR_RefreshZones($id);"
    },
    {
      "type": "Button",
      "caption": "Sequenz manuell / zeitgesteuert starten (alt)",
      "onClick": "IRR_StartManualSequence($id);"
    },
    {
      "type": "Button",
      "caption": "Automatik prüfen und starten (alt)",
      "onClick": "IRR_StartAutomaticSequence($id);"
    },
    {
      "type": "Button",
      "caption": "Sequenz stoppen",
      "onClick": "IRR_StopSequence($id);"
    }
  ],
  "status": [
    {
      "code": 102,
      "icon": "active",
      "caption": "Instanz ist aktiv"
    },
    {
      "code": 200,
      "icon": "error",
      "caption": "Keine Kreise/Zonen oder keine Pumpe konfiguriert"
    }
  ]
}
