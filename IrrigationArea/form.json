{
  "elements":[
    {"type":"ExpansionPanel","caption":"Zone","items":[
      {"name":"Enabled","type":"CheckBox","caption":"Zone aktiv"},
      {"name":"AreaNumber","type":"NumberSpinner","caption":"Reihenfolge / Zonennummer (1-10)"},
      {"name":"Mode","type":"Select","caption":"Betriebsmodus","options":[
        {"caption":"Manuell","value":1},{"caption":"Zeitsteuerung","value":2},{"caption":"Automatik","value":3}
      ]},
      {"name":"PauseBetweenZonesSeconds","type":"NumberSpinner","caption":"Pause zwischen Kreisen in dieser Zone (Sekunden)"},
      {"name":"MaxZones","type":"NumberSpinner","caption":"Maximale Kreise in dieser Zone (1-10)"}
    ]}
  ],
  "actions":[
    {"type":"Button","caption":"Neuen Kreis in dieser Zone anlegen","onClick":"IRRA_CreateZone($id);"},
    {"type":"Button","caption":"Kreise aktualisieren","onClick":"IRRA_RefreshZones($id);"},
    {"type":"Button","caption":"Zone starten","onClick":"IRRA_StartArea($id);"},
    {"type":"Button","caption":"Zone stoppen","onClick":"IRRA_StopArea($id);"}
  ],
  "status":[
    {"code":102,"icon":"active","caption":"Zone ist aktiv"},
    {"code":104,"icon":"inactive","caption":"Zone ist deaktiviert"},
    {"code":200,"icon":"error","caption":"Keine Kreise in dieser Zone vorhanden"}
  ]
}
