{
  "elements": [
    {
      "type": "ExpansionPanel",
      "caption": "Kreis",
      "items": [
        {
          "name": "Enabled",
          "type": "CheckBox",
          "caption": "Kreis aktiv",
          "onChange": "IPS_SetProperty($id, \"Enabled\", $Enabled); IPS_ApplyChanges($id);"
        },
        {
          "name": "ZoneNumber",
          "type": "NumberSpinner",
          "caption": "Reihenfolge / Kreisnummer (1-10)"
        },
        {
          "name": "Duration",
          "type": "NumberSpinner",
          "caption": "Beregnungsdauer (Minuten)",
          "visible": "$Enabled"
        },
        {
          "name": "MoistureThreshold",
          "type": "NumberSpinner",
          "caption": "Feuchteschwelle (%)",
          "visible": "$Enabled"
        },
        {
          "name": "MoistureMode",
          "type": "Select",
          "caption": "Feuchteauswertung",
          "visible": "$Enabled",
          "options": [
            { "caption": "Niedrigster Feuchtigkeitswert", "value": 0 },
            { "caption": "Durchschnitt der Sensoren", "value": 1 }
          ]
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Sensoren",
      "visible": "$Enabled",
      "items": [
        {
          "name": "MoistureSensor1",
          "type": "SelectVariable",
          "caption": "Feuchtesensor 1"
        },
        {
          "name": "MoistureSensor2",
          "type": "SelectVariable",
          "caption": "Feuchtesensor 2 optional"
        },
        {
          "name": "RainLast24h",
          "type": "SelectVariable",
          "caption": "Regen letzte 24 h optional"
        },
        {
          "name": "RainThreshold24h",
          "type": "NumberSpinner",
          "caption": "Regensperre ab mm / 24 h (0 = aus)"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Aktoren",
      "visible": "$Enabled",
      "items": [
        {
          "name": "Actuator1Instance",
          "type": "SelectInstance",
          "caption": "Aktor 1 Instanz (Shelly oder xComfort, optional)"
        },
        {
          "name": "Actuator2Instance",
          "type": "SelectInstance",
          "caption": "Aktor 2 Instanz (Shelly oder xComfort, optional)"
        },
        {
          "name": "DelayBetweenActuatorsMs",
          "type": "NumberSpinner",
          "caption": "Pause zwischen Aktor 1 und Aktor 2 (Millisekunden)"
        },
        {
          "type": "Label",
          "caption": "Beide Aktoren sind optional. Das Modul sucht unter der Instanz automatisch die passende schaltbare Bool-Variable und schaltet diese mit RequestAction. Bei xComfort kann eine kurze Pause zwischen zwei Schaltbefehlen notwendig sein."
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Werte aktualisieren",
      "visible": "$Enabled",
      "onClick": "IRRZ_RefreshValues($id);"
    },
    {
      "type": "Button",
      "caption": "Automatikentscheidung prüfen",
      "visible": "$Enabled",
      "onClick": "IRRZ_Evaluate($id);"
    },
    {
      "type": "Button",
      "caption": "Kreis manuell starten",
      "visible": "$Enabled",
      "onClick": "IRRZ_StartZone($id);"
    },
    {
      "type": "Button",
      "caption": "Kreis stoppen",
      "visible": "$Enabled",
      "onClick": "IRRZ_StopZone($id);"
    }
  ],
  "status": [
    {
      "code": 102,
      "icon": "active",
      "caption": "Kreis ist aktiv"
    },
    {
      "code": 104,
      "icon": "inactive",
      "caption": "Kreis ist deaktiviert"
    },
    {
      "code": 200,
      "icon": "error",
      "caption": "Kein Aktor konfiguriert"
    }
  ]
}
